# =============================================================
# Jamali Parfum — Variables d'environnement
# Copiez ce fichier en .env et remplissez vos valeurs réelles
# =============================================================

# ─── Serveur ─────────────────────────────────────────────────
PORT=5000
FLASK_ENV=production

# ─── MongoDB (local Docker) ───────────────────────────────────
# Ne pas changer si vous utilisez docker-compose
MONGO_URI=mongodb://jamali-mongo:27017/jamali_db

# ─── Google Gemini (Chatbot IA) ───────────────────────────────
# Obtenez votre clé sur https://aistudio.google.com
GEMINI_API_KEY=votre_cle_api_gemini_ici

# ─── Twilio WhatsApp ──────────────────────────────────────────
# Obtenez vos identifiants sur https://console.twilio.com
TWILIO_ACCOUNT_SID=votre_twilio_sid
TWILIO_AUTH_TOKEN=votre_twilio_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
ADMIN_WHATSAPP_NUMBER=whatsapp:+212700762849

# ─── Notifications Email (Gmail SMTP) ────────────────────────
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=votre_email@gmail.com
SMTP_PASSWORD=votre_mot_de_passe_application
ADMIN_EMAIL=admin@jamaliparfum.com
