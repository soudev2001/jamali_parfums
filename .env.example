# =============================================================
# Jamali Parfum — Variables d'environnement
# Copiez ce fichier en .env et remplissez vos valeurs réelles
# =============================================================

# ─── Serveur ─────────────────────────────────────────────────
PORT=5000
FLASK_ENV=production

# ─── MongoDB (Docker local avec authentification) ────────────
# Ne pas modifier si vous utilisez docker-compose
MONGO_URI=mongodb://jamali_admin:JamaliApp2026@jamali-mongo:27017/jamali_db?authSource=jamali_db
MONGO_ROOT_PASSWORD=changeme_strong_password

# ─── Google Gemini (Chatbot IA) ───────────────────────────────
# Obtenez votre clé sur https://aistudio.google.com
GEMINI_API_KEY=votre_cle_api_gemini_ici

# ─── Notifications Gmail SMTP ────────────────────────────────
# Utilisez un "Mot de passe d'application" Gmail (pas votre vrai mdp)
# https://myaccount.google.com/apppasswords
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=votre_email@gmail.com
SMTP_PASSWORD=xxxx_xxxx_xxxx_xxxx
ADMIN_EMAIL=votre_email@gmail.com
